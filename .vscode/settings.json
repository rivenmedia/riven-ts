{
  "cSpell.words": [
    "btih",
    "bullmq",
    "codegen",
    "deserialise",
    "deserialiser",
    "imdb",
    "imdbid",
    "infohash",
    "kubb",
    "listrr",
    "mikro",
    "Millis",
    "promisable",
    "serialiser",
    "serialisers",
    "strem",
    "stremthru",
    "stringbool",
    "thru",
    "tmdb",
    "torrentio",
    "torz",
    "torznab",
    "tvdb",
    "tvsearch",
    "zkochan"
  ],
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": ["node:test"],
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.tsserver.useSyntaxServer": "auto",
  "js/ts.tsserver.watchOptions": {
    "excludeDirectories": [
      "**/node_modules",
      "**/docker-data",
      "**/.git",
      "**/dist",
      "**/coverage",
      "**/.turbo",
      "**/logs",
      "**/temp",
      "**/docs",
      "**/__generated__",
      "**/plex"
    ]
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/node_modules/**": true,
    "**/__generated__/**": true,
    "**/*.log": true,
    "**/docker-data/**": true,
    "**/dist/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/dist": true
  }
}
