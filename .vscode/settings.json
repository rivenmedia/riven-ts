{
  "cSpell.words": [
    "arktype",
    "bullmq",
    "deserialise",
    "Deserialiser",
    "imdb",
    "kubb",
    "listrr",
    "Promisable",
    "serialiser",
    "serialisers",
    "stringbool",
    "TMDB",
    "torrentio",
    "tvdb",
    "zkochan"
  ],
  // allow autocomplete for ArkType expressions like "string | num"
  "editor.quickSuggestions": {
    "strings": "on"
  },
  // prioritize ArkType's "type" for autoimports
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": ["^(node:)?os$"],
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.tsserver.useSyntaxServer": "auto",
  "js/ts.tsserver.watchOptions": {
    "excludeDirectories": [
      "**/node_modules",
      "**/docker-data",
      "**/.git",
      "**/dist",
      "**/coverage",
      "**/.turbo",
      "**/logs",
      "**/temp",
      "**/docs",
      "**/__generated__",
      "**/plex"
    ]
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/node_modules/**": true,
    "**/__generated__/**": true,
    "**/*.log": true,
    "**/docker-data/**": true,
    "**/dist/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/dist": true
  }
}
