  "js/ts.preferences.autoImportSpecifierExcludeRegexes": ["node:test"],
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.tsserver.useSyntaxServer": "auto",
  "js/ts.tsserver.watchOptions": {
    "excludeDirectories": [
      "**/node_modules",
      "**/docker-data",
      "**/.git",
      "**/dist",
      "**/coverage",
      "**/.turbo",
      "**/logs",
      "**/temp",
      "**/docs",
      "**/__generated__",
      "**/plex"
    ]
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/node_modules/**": true,
    "**/__generated__/**": true,
    "**/*.log": true,
    "**/docker-data/**": true,
    "**/dist/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/dist": true,
    "**/.snapshot-riven.json": true,
    "**/Migration*.ts": true
  },
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "oxc.typeAware": true
}
