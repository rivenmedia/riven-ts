{
  "cSpell.words": [
    "bullmq",
    "deserialise",
    "Deserialiser",
    "imdb",
    "kubb",
    "listrr",
    "Promisable",
    "serialiser",
    "serialisers",
    "stringbool",
    "TMDB",
    "torrentio",
    "tvdb",
    "zkochan"
  ],
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": ["node:test"],
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.tsserver.useSyntaxServer": "auto",
  "js/ts.tsserver.watchOptions": {
    "excludeDirectories": [
      "**/node_modules",
      "**/.git",
      "**/dist",
      "**/coverage",
      "**/.turbo",
      "**/logs",
      "**/temp",
      "**/docs",
      "**/__generated__"
    ]
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/node_modules/**": true,
    "**/__generated__/**": true,
    "**/*.log": true
  },
  "wallaby.compactStatus": true
}
