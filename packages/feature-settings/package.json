{
  "name": "@repo/feature-settings",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./resolver": {
      "types": "./lib/schema/settings.resolver.ts",
      "default": "./dist/schema/settings.resolver.js"
    },
    "./settings.type": {
      "types": "./lib/schema/types/settings.type.ts",
      "default": "./dist/schema/types/settings.type.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.lib.json",
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@rivenmedia/plugin-sdk": "workspace:^",
    "type-graphql": "catalog:"
  },
  "devDependencies": {
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@repo/core-util-vitest-config": "workspace:^",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "msw": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
