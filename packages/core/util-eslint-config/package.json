{
  "name": "@repo/core-util-eslint-config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./lib/base.ts",
    "./svelte": "./lib/svelte.ts",
    "./typescript": "./lib/typescript.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix"
  },
  "dependencies": {
    "@eslint/js": "catalog:",
    "@eslint/json": "catalog:",
    "@repo/core-util-typescript-config": "workspace:^",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-config-turbo": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-svelte": "catalog:",
    "globals": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "devDependencies": {
    "@sveltejs/kit": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": "^8",
    "eslint": "^9"
  }
}
