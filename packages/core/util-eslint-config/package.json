{
  "name": "@repo/core-util-eslint-config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": [
      "./lib/*.ts"
    ]
  },
  "exports": {
    ".": "./lib/base.ts",
    "./nextjs": "./lib/nextjs.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "lint": "oxlint",
    "lint:fix": "pnpm lint --fix"
  },
  "dependencies": {
    "@eslint/json": "catalog:",
    "@repo/core-util-typescript-config": "workspace:^",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/eslint-plugin": "catalog:",
    "eslint-plugin-turbo": "catalog:",
    "globals": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": "^8",
    "oxlint": "^1",
    "oxlint-tsgolint": "^0.25.0"
  }
}
