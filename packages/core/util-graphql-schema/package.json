{
  "name": "@repo/core-util-graphql-schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.ts",
      "default": "./dist/index.js"
    },
    "./context": {
      "types": "./lib/context.ts",
      "default": "./dist/context.js"
    },
    "./cache-control-directive": {
      "types": "./lib/cache-control.directive.ts",
      "default": "./dist/cache-control.directive.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.lib.json",
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "graphql": "catalog:",
    "graphql-scalars": "catalog:",
    "type-graphql": "catalog:"
  },
  "devDependencies": {
    "@apollo/cache-control-types": "^1.0.3",
    "@mikro-orm/core": "catalog:",
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@repo/core-util-vitest-config": "workspace:^",
    "@rivenmedia/plugin-sdk": "workspace:^",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
