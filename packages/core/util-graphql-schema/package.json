{
  "name": "@repo/core-util-graphql-schema",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./lib/index.ts"
    }
