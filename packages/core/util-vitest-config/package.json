{
  "name": "@repo/core-util-vitest-config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./base": "./lib/base.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "collect-json-reports": "node lib/scripts/collect-json-outputs.ts",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "merge-json-reports": "nyc merge coverage/raw coverage/merged/merged-coverage.json",
    "report": "pnpm report:html && pnpm report:summary",
    "report:html": "nyc report -t coverage/merged --report-dir coverage/report --reporter=html --exclude-after-remap false",
    "report:summary": "nyc report -t coverage/merged --report-dir coverage/summary --reporter=json-summary --exclude-after-remap false",
    "view-report": "open coverage/report/index.html"
  },
  "dependencies": {
    "@swc/core": "^1.15.7",
    "unplugin-swc": "^1.5.9"
  },
  "devDependencies": {
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "glob": "catalog:",
    "msw": "catalog:",
    "nyc": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@vitest/coverage-v8": "^4.0.0",
    "msw": "^2.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "msw": {
      "optional": true
    }
  }
}
