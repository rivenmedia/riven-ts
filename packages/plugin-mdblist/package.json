{
  "name": "@rivenmedia/riven-plugin-mdblist",
  "version": "0.0.0",
  "keywords": [
    "riven-plugin"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.lib.json",
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "codegen:api-schemas": "kubb generate",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apollo/datasource-rest": "catalog:",
    "@rivenmedia/plugin-sdk": "workspace:^",
    "type-graphql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "catalog:",
    "@kubb/cli": "catalog:",
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-graphql-helpers": "workspace:^",
    "@repo/core-util-kubb-config": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@repo/core-util-vitest-config": "workspace:^",
    "@repo/util-plugin-testing": "workspace:^",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "class-validator": "catalog:",
    "eslint": "catalog:",
    "msw": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
