{
  "name": "@repo/util-plugin-sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./types/*": "./dist/types/*.js",
    "./dto/entities": "./dist/dto/entities/index.js",
    "./dto/enums/*": "./dist/dto/enums/*.js",
    "./dto/repositories/*": "./dist/dto/repositories/*.js",
    "./dto/unions/*": "./dist/dto/unions/*.js",
    "./errors/*": "./dist/errors/*.js",
    "./events": "./dist/schemas/events/index.js",
    "./events/*": "./dist/schemas/plugin-to-program-events/*.js",
    "./schemas/*": "./dist/schemas/*.js",
    "./helpers/*": "./dist/helpers/*.js",
    "./testing/*": "./dist/testing/*.js",
    "./utilities/*": "./dist/utilities/*.js",
    "./validation": "./dist/validation/index.js"
  },
  "scripts": {
    "build": "tsc --build tsconfig.lib.json",
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
