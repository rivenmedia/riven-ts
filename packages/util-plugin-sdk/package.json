{
  "name": "@repo/util-plugin-sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": [
      "./lib/index.ts",
      "./dist/index.js"
    ],
    "./types/*": [
      "./lib/types/*.ts",
      "./dist/types/*.js"
    ],
    "./dto/entities": [
      "./lib/dto/entities/index.ts",
      "./dist/dto/entities/index.js"
    ],
    "./dto/enums/*": [
      "./lib/dto/enums/*.ts",
      "./dist/dto/enums/*.js"
    ],
    "./dto/repositories/*": [
      "./lib/dto/repositories/*.ts",
      "./dist/dto/repositories/*.js"
    ],
    "./dto/unions/*": [
      "./lib/dto/unions/*.ts",
      "./dist/dto/unions/*.js"
    ],
    "./errors/*": [
      "./lib/errors/*.ts",
      "./dist/errors/*.js"
    ],
    "./events": [
      "./lib/schemas/events/index.ts",
      "./dist/schemas/events/index.js"
    ],
    "./events/*": [
      "./lib/schemas/plugin-to-program-events/*.ts",
      "./dist/schemas/plugin-to-program-events/*.js"
    ],
    "./schemas/*": [
      "./lib/schemas/*.ts",
      "./dist/schemas/*.js"
    ],
    "./helpers/*": [
      "./lib/helpers/*.ts",
      "./dist/helpers/*.js"
    ],
    "./testing/*": [
      "./lib/testing/*.ts",
      "./dist/testing/*.js"
    ],
    "./utilities/*": [
      "./lib/utilities/*.ts",
      "./dist/utilities/*.js"
    ],
    "./validation": [
      "./lib/validation/index.ts",
      "./dist/validation/index.js"
    ]
  },
  "scripts": {
    "build": "tsc --build tsconfig.lib.json",
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mikro-orm/decorators": "catalog:",
    "@repo/util-rank-torrent-name": "workspace:^",
    "es-toolkit": "catalog:",
    "luxon": "catalog:",
    "zod": "catalog:",
    "zod-validation-error": "catalog:"
  },
  "devDependencies": {
    "@apollo/client": "^4.0.11",
    "@apollo/datasource-rest": "catalog:",
    "@apollo/server": "^5.2.0",
    "@apollo/utils.keyvadapter": "catalog:",
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/postgresql": "catalog:",
    "@mikro-orm/reflection": "catalog:",
    "@mikro-orm/sqlite": "catalog:",
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@repo/core-util-vitest-config": "workspace:^",
    "@types/luxon": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "bullmq": "catalog:",
    "class-validator": "catalog:",
    "eslint": "catalog:",
    "limiter": "catalog:",
    "msw": "catalog:",
    "type-graphql": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "winston": "catalog:",
    "xstate": "catalog:"
  },
  "peerDependencies": {
    "@apollo/client": "^4.0.11",
    "@apollo/datasource-rest": "catalog:",
    "@apollo/utils.keyvadapter": "catalog:",
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/postgresql": "catalog:",
    "@mikro-orm/reflection": "catalog:",
    "bullmq": "catalog:",
    "class-validator": "catalog:",
    "limiter": "catalog:",
    "xstate": "^5.25.0"
  }
}
