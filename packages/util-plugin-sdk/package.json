{
  "name": "@rivenmedia/plugin-sdk",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.ts",
      "default": "./dist/index.js"
    },
    "./types/*": {
      "types": "./lib/types/*.ts",
      "default": "./dist/types/*.js"
    },
    "./graphql/*": {
      "types": "./lib/graphql/*.ts",
      "default": "./dist/graphql/*.js"
    },
    "./dto/entities": {
      "types": "./lib/dto/entities/index.ts",
      "default": "./dist/dto/entities/index.js"
    },
    "./dto/enums/*": {
      "types": "./lib/dto/enums/*.ts",
      "default": "./dist/dto/enums/*.js"
    },
    "./dto/repositories/*": {
      "types": "./lib/dto/repositories/*.ts",
      "default": "./dist/dto/repositories/*.js"
    },
    "./dto/unions/*": {
      "types": "./lib/dto/unions/*.ts",
      "default": "./dist/dto/unions/*.js"
    },
    "./errors/*": {
      "types": "./lib/errors/*.ts",
      "default": "./dist/errors/*.js"
    },
    "./events": {
      "types": "./lib/schemas/events/index.ts",
      "default": "./dist/schemas/events/index.js"
    },
    "./schemas/*": {
      "types": "./lib/schemas/*.ts",
      "default": "./dist/schemas/*.js"
    },
    "./helpers/*": {
      "types": "./lib/helpers/*.ts",
      "default": "./dist/helpers/*.js"
    },
    "./testing/*": {
      "types": "./lib/testing/*.ts",
      "default": "./dist/testing/*.js"
    },
    "./utilities/*": {
      "types": "./lib/utilities/*.ts",
      "default": "./dist/utilities/*.js"
    },
    "./validation": {
      "types": "./lib/validation/index.ts",
      "default": "./dist/validation/index.js"
    },
    "./datasource-context": {
      "types": "./lib/datasource/context.ts",
      "default": "./dist/datasource/context.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.lib.json",
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mikro-orm/decorators": "catalog:",
    "@repo/util-rank-torrent-name": "workspace:^",
    "es-toolkit": "catalog:",
    "graphql-scalars": "catalog:",
    "luxon": "catalog:",
    "zod": "catalog:",
    "zod-validation-error": "catalog:"
  },
  "devDependencies": {
    "@apollo/client": "^4.0.11",
    "@apollo/datasource-rest": "catalog:",
    "@apollo/server": "^5.2.0",
    "@apollo/utils.keyvadapter": "catalog:",
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/postgresql": "catalog:",
    "@mikro-orm/reflection": "catalog:",
    "@mikro-orm/sqlite": "catalog:",
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@repo/core-util-vitest-config": "workspace:^",
    "@types/luxon": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "bullmq": "catalog:",
    "class-validator": "catalog:",
    "eslint": "catalog:",
    "msw": "catalog:",
    "type-graphql": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "winston": "catalog:",
    "xstate": "catalog:"
  },
  "peerDependencies": {
    "@apollo/client": "^4.0.11",
    "@apollo/datasource-rest": "catalog:",
    "@apollo/utils.keyvadapter": "catalog:",
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/postgresql": "catalog:",
    "@mikro-orm/reflection": "catalog:",
    "bullmq": "catalog:",
    "class-validator": "catalog:",
    "xstate": "^5.25.0"
  }
}
