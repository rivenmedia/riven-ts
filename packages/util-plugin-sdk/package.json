{
  "name": "@repo/util-plugin-sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./lib/index.ts"
    },
    "./types/*": {
      "production": "./dist/types/*.js",
      "default": "./lib/types/*.ts"
    },
    "./dto/entities": {
      "production": "./dist/dto/entities/index.js",
      "default": "./lib/dto/entities/index.ts"
    },
    "./dto/enums/*": {
      "production": "./dist/dto/enums/*.js",
      "default": "./lib/dto/enums/*.ts"
    },
    "./dto/repositories/*": {
      "production": "./dist/dto/repositories/*.js",
      "default": "./lib/dto/repositories/*.ts"
    },
    "./dto/unions/*": {
      "production": "./dist/dto/unions/*.js",
      "default": "./lib/dto/unions/*.ts"
    },
    "./errors/*": {
      "production": "./dist/errors/*.js",
      "default": "./lib/errors/*.ts"
    },
    "./events": {
      "production": "./dist/schemas/events/index.js",
      "default": "./lib/schemas/events/index.ts"
    },
    "./schemas/*": {
      "production": "./dist/schemas/*.js",
      "default": "./lib/schemas/*.ts"
    },
    "./helpers/*": {
      "production": "./dist/helpers/*.js",
      "default": "./lib/helpers/*.ts"
    },
    "./utilities/*": {
      "production": "./dist/utilities/*.js",
      "default": "./lib/utilities/*.ts"
    },
    "./validation": {
      "production": "./dist/validation/index.js",
      "default": "./lib/validation/index.ts"
    },
    "./datasource-context": {
      "production": "./dist/datasource/context.js",
      "default": "./lib/datasource/context.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.lib.json",
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mikro-orm/decorators": "catalog:",
    "@repo/util-rank-torrent-name": "workspace:^",
    "es-toolkit": "catalog:",
    "graphql-scalars": "catalog:",
    "luxon": "catalog:",
    "type-graphql": "catalog:",
    "zod": "catalog:",
    "zod-validation-error": "catalog:"
  },
  "devDependencies": {
    "@apollo/datasource-rest": "catalog:",
    "@apollo/utils.keyvadapter": "catalog:",
    "@keyv/redis": "catalog:",
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/reflection": "catalog:",
    "@mikro-orm/sqlite": "catalog:",
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@repo/core-util-vitest-config": "workspace:^",
    "@types/luxon": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "bullmq": "catalog:",
    "class-validator": "catalog:",
    "eslint": "catalog:",
    "msw": "catalog:",
    "redis-memory-server": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "winston": "catalog:"
  },
  "peerDependencies": {
    "@apollo/datasource-rest": "catalog:",
    "@mikro-orm/core": "catalog:",
    "bullmq": "catalog:",
    "class-validator": "catalog:"
  }
}
