{
  "name": "@repo/util-auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./access-control": {
      "production": "./dist/access-control.js",
      "default": "./lib/access-control.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.lib.json",
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-auth": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@repo/core-util-vitest-config": "workspace:^",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
