{
  "name": "@repo/util-rank-torrent-name",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.js",
      "default": "./lib/index.ts"
    },
    "./parser": {
      "production": "./dist/parser/parse.js",
      "default": "./lib/parser/parse.ts"
    },
    "./wiki.config": "./wiki.config.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.lib.json",
    "check-types": "tsc --noEmit --project tsconfig.lib.json && tsc --noEmit --project tsconfig.spec.json",
    "codegen:config-docs": "pnpm node scripts/generate-zod-docs.ts",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@repo/util-wiki-helpers": "workspace:^",
    "@viren070/parse-torrent-title": "catalog:",
    "es-toolkit": "catalog:",
    "fastest-levenshtein": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@repo/core-util-vitest-config": "workspace:^",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
