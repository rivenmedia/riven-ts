{
  {{#if (equals packageType 'plugin')}}
  "name": "@repo/{{packageType}}-{{kebabCase pluginName}}",
  {{else}}
  "name": "@repo/{{packageType}}-{{kebabCase packageName}}",
  {{/if}}
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    {{#with (packageJsonFields packageType 'scripts') as |scripts|}}
    {{#if scripts}}
    {{#each scripts}}
    "{{@key}}": "{{{this}}}"{{#unless @last}},{{/unless}}
    {{/each}}
    {{/if}}
    {{/with}}
  },
  {{#with (packageJsonFields packageType 'files') as |files|}}
  {{#if files}}
  "files": [
    {{#each files}}
    "{{this}}"{{#unless @last}},{{/unless}}
    {{/each}}
  ],
  {{/if}}
  {{/with}}
  {{!-- Output dependencies for the package based on the packageJsonFields helper --}}
  "exports": {
    {{#with (packageJsonFields packageType 'exports') as |exports|}}
    {{#if exports}}
    {{#each exports}}
    {{#if this}}
    "{{@key}}": {{{json this}}}{{#unless @last}},{{/unless}}
    {{/if}}
    {{/each}}
    {{/if}}
    {{/with}}
  },
  {{!-- Output dependencies for the package based on the packageJsonFields helper --}}
  {{#each (array "dependencies" "devDependencies" "peerDependencies")}}
  {{#with (packageJsonFields ../packageType this) as |deps|}}
  {{#if deps}}
  "{{../this}}": {
    {{#each deps}}
    "{{@key}}": "{{this}}"{{#unless @last}},{{/unless}}
    {{/each}}
  },
  {{/if}}
  {{/with}}
  {{/each}}
  {{!-- Add a field at the end to avoid trailing comma issues --}}
  "private": true
}
