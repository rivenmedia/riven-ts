{
  "name": "riven-ts",
  "version": "0.0.1",
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "Riven Media",
  "type": "module",
  "scripts": {
    "format:check": "prettier --check . '!**/docker-data'",
    "format:check:ci": "pnpm format:check --log-level warn",
    "format:fix": "prettier --write . '!**/docker-data'",
    "postinstall": "pnpm node .husky/install.mjs || true",
    "knip": "pnpm knip:prepare && knip",
    "knip:ci:base": "pnpm knip --cache --no-exit-code",
    "knip:ci:development": "pnpm knip:ci:base --reporter github-actions",
    "knip:ci:production": "pnpm knip:ci:base --strict --reporter json | tail -1 > knip-report.json",
    "knip:prepare": "turbo codegen:api-schemas"
  },
  "devDependencies": {
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@trivago/prettier-plugin-sort-imports": "catalog:",
    "@turbo/gen": "catalog:",
    "@types/node": "catalog:",
    "es-toolkit": "catalog:",
    "eslint": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "sort-package-json": "catalog:",
    "turbo": "catalog:",
    "type-fest": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.15.0"
    }
  },
  "pnpm": {
    "overrides": {
      "@protobufjs/utf8@<1.1.1": ">=1.1.1",
      "ajv@>=8 <8.20.0": ">=8.20.0",
      "brace-expansion@>=2 <2.1.0": ">=2.1.0",
      "cookie@<0.7.0": ">=0.7.0",
      "flatted@<3.4.2": ">=3.4.2",
      "lodash@<4.18.1": ">=4.18.1",
      "lodash-es@<4.18.1": ">=4.18.1",
      "minimatch@>=9 <9.0.9": ">=9.0.9",
      "qs@>=6 <6.15.1": ">=6.15.1",
      "tar@>=7 <7.5.15": ">=7.5.15"
    }
  }
}
