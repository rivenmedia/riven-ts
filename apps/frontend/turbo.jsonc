{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "dev": {
      "with": ["@repo/riven#dev"]
    },
    "codegen:gql": {
      "dependsOn": ["@repo/riven#codegen:gql-schema"]
    },
    "e2e": {
      "passThroughEnv": ["DATABASE_FILE_NAME"]
    },
    "e2e:headless": {}
  }
}
