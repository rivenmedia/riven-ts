{
  "$schema": "https://www.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDirs": ["lib", "app", "components", "environment"],
    "outDir": "dist",
    "noEmit": false
  },
  "files": ["next-env.d.ts"],
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.mts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "components/**/*.mts",
    "environment/**/*.ts",
    "environment/**/*.tsx",
    "environment/**/*.mts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "lib/**/*.mts"
  ],
  "exclude": [
    "app/**/*.spec.ts",
    "components/**/*.spec.ts",
    "environment/**/*.spec.ts",
    "lib/**/*.spec.ts",
    "**/__tests__/**/*.ts"
  ]
}
