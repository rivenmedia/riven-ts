{
  "$schema": "https://www.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDirs": ["lib", "temp"],
    "outDir": "dist",
    "noEmit": false
  },
  "files": ["temp/metadata.json", "package.json"],
  "include": ["lib/**/*.ts", "lib/**/*.mts", "lib/**/*.cts"],
  "exclude": ["lib/**/*.spec.ts", "**/__tests__/**/*.ts"]
}
