{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build:workers": {
      "outputs": ["dist/workers/**"]
    },
    "dev": {
      "dependsOn": ["^build", "build:workers"],
      "passThroughEnv": [
        "SENTRY_SPOTLIGHT",
        "SENTRY_SPOTLIGHT_CLEAR_ON_STARTUP"
      ]
    },
    "start": {}
  }
}
