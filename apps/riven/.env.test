# Core settings

## PostgreSQL database connection URL
RIVEN_SETTING__databaseUrl="postgresql+psycopg2://postgres:postgres@riven-db/riven"

## Enable VFS debug logging
RIVEN_SETTING__vfsDebugLogging=false

## Riven VFS mount path
RIVEN_SETTING__vfsMountPath="/mnt/test-vfs-mount"

## Clear queues on startup
RIVEN_SETTING__unsafeClearQueuesOnStartup=false

## Refresh database on startup
RIVEN_SETTING__unsafeRefreshDatabaseOnStartup=false

## Disable logging
RIVEN_SETTING__loggingEnabled=false

# Only write to the console (for debugging when logging enabled)
RIVEN_SETTING__enabledLogTransports=["console"]

## Application log level
RIVEN_SETTING__logLevel="silly"

## Application log directory
RIVEN_SETTING__logDirectory="logs"
