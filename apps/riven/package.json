{
  "name": "@repo/riven",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./workers/map-items-to-files": {
      "production": "./workers/map-items-to-files/map-items-to-files.processor.js",
      "default": "./lib/message-queue/sandboxed-jobs/jobs/map-items-to-files/map-items-to-files.processor.ts"
    },
    "./workers/parse-scrape-results": {
      "production": "./workers/parse-scrape-results/parse-scrape-results.processor.js",
      "default": "./lib/message-queue/sandboxed-jobs/jobs/parse-scrape-results/parse-scrape-results.processor.ts"
    },
    "./workers/validate-torrent-files": {
      "production": "./workers/validate-torrent-files/validate-torrent-files.processor.js",
      "default": "./lib/message-queue/sandboxed-jobs/jobs/validate-torrent-files/validate-torrent-files.processor.ts"
    },
    "./database-metadata-cache": "./temp/metadata.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm build:program",
    "build:program": "tsc --build tsconfig.app.json",
    "build:workers": "rm -rf dist/workers && pnpm node esbuild.config.ts",
    "check-types": "tsc --noEmit --project tsconfig.app.json && tsc --noEmit --project tsconfig.spec.json",
    "codegen:config-docs": "zod2md",
    "codegen:gql": "graphql-codegen --config graphql-codegen.ts",
    "codegen:gql-schema": "node --import=@swc-node/register/esm-register scripts/generate-gql-schema.ts",
    "database:cache:generate": "mikro-orm cache:generate --combined --contextName slim",
    "dev": "pnpm node --watch --env-file-if-exists=.env.riven --import=@swc-node/register/esm-register --enable-source-maps lib/index.ts",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "migration:check": "mikro-orm migration:check",
    "migration:create": "mikro-orm migration:create",
    "mikro-orm": "mikro-orm",
    "start": "pnpm node --conditions=production --env-file-if-exists=.env.riven --enable-source-maps dist/lib/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apollo/client": "catalog:",
    "@apollo/server": "catalog:",
    "@apollo/utils.keyvadapter": "catalog:",
    "@apollo/utils.keyvaluecache": "catalog:",
    "@elastic/ecs-winston-format": "catalog:",
    "@keyv/redis": "catalog:",
    "@mikro-orm/core": "catalog:",
    "@mikro-orm/decorators": "catalog:",
    "@mikro-orm/migrations": "catalog:",
    "@mikro-orm/postgresql": "catalog:",
    "@mikro-orm/reflection": "catalog:",
    "@repo/core-util-graphql-schema": "workspace:^",
    "@repo/plugin-comet": "workspace:^",
    "@repo/plugin-listrr": "workspace:^",
    "@repo/plugin-mdblist": "workspace:^",
    "@repo/plugin-notifications": "workspace:^",
    "@repo/plugin-plex": "workspace:^",
    "@repo/plugin-seerr": "workspace:^",
    "@repo/plugin-stremthru": "workspace:^",
    "@repo/plugin-subdl": "workspace:^",
    "@repo/plugin-tmdb": "workspace:^",
    "@repo/plugin-torrentio": "workspace:^",
    "@repo/plugin-tvdb": "workspace:^",
    "@repo/util-plugin-sdk": "workspace:^",
    "@repo/util-rank-torrent-name": "workspace:^",
    "@sentry/node": "catalog:",
    "@zkochan/fuse-native": "catalog:",
    "bullmq": "catalog:",
    "bullmq-otel": "catalog:",
    "chalk": "catalog:",
    "class-validator": "catalog:",
    "dataloader": "catalog:",
    "dedent": "catalog:",
    "es-toolkit": "catalog:",
    "graphql": "catalog:",
    "graphql-scalars": "catalog:",
    "keyv": "catalog:",
    "lru-cache": "catalog:",
    "luxon": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "triple-beam": "catalog:",
    "type-graphql": "catalog:",
    "undici": "catalog:",
    "winston": "catalog:",
    "winston-daily-rotate-file": "catalog:",
    "xstate": "catalog:",
    "zod": "catalog:",
    "zod-validation-error": "catalog:"
  },
  "devDependencies": {
    "@apollo/client-devtools-vscode": "catalog:",
    "@faker-js/faker": "catalog:",
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/near-operation-file-preset": "catalog:",
    "@graphql-codegen/typescript": "catalog:",
    "@graphql-codegen/typescript-operations": "catalog:",
    "@graphql-typed-document-node/core": "catalog:",
    "@mikro-orm/cli": "catalog:",
    "@mikro-orm/seeder": "catalog:",
    "@mikro-orm/sqlite": "catalog:",
    "@parcel/watcher": "catalog:",
    "@repo/core-util-eslint-config": "workspace:^",
    "@repo/core-util-mock-graphql-server": "workspace:^",
    "@repo/core-util-typescript-config": "workspace:^",
    "@repo/core-util-vitest-config": "workspace:^",
    "@repo/plugin-test": "workspace:^",
    "@swc-node/register": "catalog:",
    "@types/luxon": "catalog:",
    "@types/node": "catalog:",
    "@types/triple-beam": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/expect": "catalog:",
    "esbuild": "catalog:",
    "esbuild-node-externals": "catalog:",
    "eslint": "catalog:",
    "logform": "catalog:",
    "msw": "catalog:",
    "redis-memory-server": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod2md": "catalog:"
  },
  "mikro-orm": {
    "configPaths": [
      "./lib/mikro-orm.config.ts"
    ]
  }
}
