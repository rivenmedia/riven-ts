diff --git a/include.js b/include.js
index 78486a7..e092c9c 100644
--- a/include.js
+++ b/include.js
@@ -1,18 +1,22 @@
 const os = require('os')
 
 const arch = os.arch()
-const platform = os.platform() + (arch === 'arm' ? '-arm' : '')
+const platform = os.platform() + (arch === 'arm' ? '-arm' : '') + (arch === 'arm64' ? '-arm64' : '')
 
 switch (platform) {
   case 'linux':
     require('fuse-shared-library-linux/include')
     break
   case 'darwin':
+  case 'darwin-arm':
     require('fuse-shared-library-darwin/include')
     break
   case 'linux-arm':
     require('fuse-shared-library-linux-arm/include')
     break
+  case 'linux-arm64':
+    require('fuse-shared-library-linux-arm64/include')
+    break
   case 'win32':
     require('fuse-shared-library-win32/include')
     break
